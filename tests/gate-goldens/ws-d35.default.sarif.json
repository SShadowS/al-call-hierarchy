              }
            },
            {
              "id": "d17-min-version-drift",
              "name": "MinVersionDrift",
              "shortDescription": {
                "text": "Call into API newer than declared MinVersion"
              }
            },
            {
              "id": "d46-commit-in-lifecycle",
              "name": "CommitInLifecycle",
              "shortDescription": {
                "text": "Commit reachable from an Install/Upgrade codeunit trigger"
              }
            },
            {
              "id": "d47-io-unsafe-txn",
              "name": "IoUnsafeTxn",
              "shortDescription": {
                "text": "External IO inside an open write transaction / before commit"
              }
            },
            {
              "id": "d48-io-in-loop",
              "name": "IoInLoop",
              "shortDescription": {
                "text": "External IO (HTTP/FILE) inside a loop"
              }
            },
            {
              "id": "d49-uncommitted-write-before-ui",
              "name": "UncommittedWriteBeforeUi",
              "shortDescription": {
                "text": "DB write pending at a window-opening UI call (BC runtime error)"
              }
            },
            {
              "id": "d50-checked-run-implicit-commit",
              "name": "CheckedRunImplicitCommit",
              "shortDescription": {
